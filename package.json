{
  "name": "gst-record-fetcher",
  "version": "1.0.0",
  "description": "GST Record Fetcher Module - Fetches and displays GST records from official government portal",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "scrape": "node src/scrape.js",
    "server": "node server/app.js",
    "server:dev": "nodemon server/app.js",
    "mongo:start": "docker start gst-mongo >/dev/null 2>&1 || docker run -d --name gst-mongo -p 27017:27017 -v gst_mongo_data:/data/db mongo:4.4",
    "mongo:stop": "docker stop gst-mongo",
    "app:start": "npm run mongo:start && node server/app.js",
    "app:dev": "npm run mongo:start && nodemon server/app.js",
    "app:status": "docker ps --filter \"name=gst-mongo\" --format \"table {{.Names}}\\t{{.Status}}\\t{{.Ports}}\" && curl -sS http://localhost:3000/api/health",
    "arch": "node scripts/print_architecture.mjs",
    "financial:pair": "node scripts/run_financial_analysis_pair.mjs",
    "financial": "node scripts/analyze_financial_xlsx.mjs --input \"FINANCIAL FINAL.xlsx\"",
    "financial:xlsx": "node scripts/analyze_financial_xlsx.mjs",
    "migrate:mongodb": "node scripts/migrate_to_mongodb.mjs",
    "test": "node --test"
  },
  "keywords": [
    "gst",
    "india",
    "tax",
    "government",
    "data-fetcher"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1004.0",
    "axios": "^1.6.5",
    "axios-cookiejar-support": "^6.0.5",
    "chalk": "^5.3.0",
    "cheerio": "^1.0.0-rc.12",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.22.1",
    "express-rate-limit": "^7.5.1",
    "file-type": "^19.6.0",
    "helmet": "^7.2.0",
    "mongoose": "^9.2.4",
    "multer": "^1.4.5-lts.1",
    "node-cache": "^5.1.2",
    "openai": "^6.17.0",
    "ora": "^8.0.1",
    "p-queue": "^8.0.1",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.10.38",
    "pdfkit": "^0.17.2",
    "puppeteer": "^22.0.0",
    "retry": "^0.13.1",
    "tough-cookie": "^6.0.0",
    "winston": "^3.11.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.11"
  }
}
