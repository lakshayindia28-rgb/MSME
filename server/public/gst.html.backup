<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GST Record Fetcher - Government Portal Data</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        .header {
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            text-align: center;
            margin-bottom: 30px;
        }

        .header h1 {
            color: #333;
            font-size: 2.5em;
            margin-bottom: 10px;
        }

        .header p {
            color: #666;
            font-size: 1.1em;
        }

        .badge {
            display: inline-block;
            background: #4CAF50;
            color: white;
            padding: 5px 15px;
            border-radius: 20px;
            font-size: 0.85em;
            margin-top: 10px;
        }

        .demo-notice {
            background: #fff3cd;
            border-left: 4px solid #ffc107;
            padding: 15px;
            margin: 20px 0;
            border-radius: 5px;
        }

        .demo-notice h4 {
            color: #856404;
            margin-bottom: 8px;
        }

        .demo-notice p {
            color: #856404;
            margin: 0;
            font-size: 0.95em;
        }

        .captcha-container {
            display: flex;
            align-items: center;
            gap: 15px;
            margin: 20px 0;
            padding: 20px;
            background: #f8f9fa;
            border-radius: 10px;
        }

        .captcha-image {
            width: 200px;
            height: auto;
            min-height: 60px;
            border: 2px solid #ddd;
            border-radius: 8px;
            background: white;
            padding: 5px;
            cursor: pointer;
            display: block;
        }

        .captcha-input {
            flex: 1;
        }

        .refresh-btn {
            padding: 10px 20px;
            background: #6c757d;
            color: white;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-size: 1em;
        }

        .refresh-btn:hover {
            background: #5a6268;
        }

        .search-section {
            background: white;
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            margin-bottom: 30px;
        }

        .input-group {
            display: flex;
            gap: 15px;
            margin-bottom: 20px;
        }

        input[type="text"] {
            flex: 1;
            padding: 15px 20px;
            font-size: 1.1em;
            border: 2px solid #ddd;
            border-radius: 10px;
            transition: all 0.3s;
        }

        input[type="text"]:focus {
            outline: none;
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }

        button {
            padding: 15px 40px;
            font-size: 1.1em;
            font-weight: bold;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.3s;
        }

        button:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(102, 126, 234, 0.4);
        }

        button:disabled {
            opacity: 0.6;
            cursor: not-allowed;
            transform: none;
        }

        .examples {
            margin-top: 15px;
            padding: 15px;
            background: #f8f9fa;
            border-radius: 8px;
        }

        .examples h4 {
            color: #555;
            margin-bottom: 10px;
        }

        .example-gstin {
            display: inline-block;
            background: white;
            padding: 8px 15px;
            margin: 5px;
            border-radius: 5px;
            cursor: pointer;
            border: 1px solid #ddd;
            transition: all 0.2s;
        }

        .example-gstin:hover {
            background: #667eea;
            color: white;
            border-color: #667eea;
        }

        .loading {
            text-align: center;
            padding: 40px;
            display: none;
        }

        .spinner {
            border: 4px solid #f3f3f3;
            border-top: 4px solid #667eea;
            border-radius: 50%;
            width: 50px;
            height: 50px;
            animation: spin 1s linear infinite;
            margin: 0 auto 20px;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .result-section {
            background: white;
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            display: none;
        }

        .result-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            padding-bottom: 20px;
            border-bottom: 2px solid #f0f0f0;
        }

        .result-header h2 {
            color: #333;
        }

        .status-badge {
            padding: 8px 20px;
            border-radius: 20px;
            font-weight: bold;
        }

        .status-active {
            background: #4CAF50;
            color: white;
        }

        .status-inactive {
            background: #f44336;
            color: white;
        }

        .info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .info-card {
            background: #f8f9fa;
            padding: 20px;
            border-radius: 10px;
            border-left: 4px solid #667eea;
        }

        .info-card h3 {
            color: #555;
            font-size: 0.9em;
            margin-bottom: 8px;
            text-transform: uppercase;
        }

        .info-card p {
            color: #333;
            font-size: 1.1em;
            font-weight: 500;
        }

        .address-section {
            background: #f8f9fa;
            padding: 25px;
            border-radius: 10px;
            margin-top: 20px;
        }

        .address-section h3 {
            color: #333;
            margin-bottom: 15px;
        }

        .activities-section {
            margin-top: 30px;
        }

        .activities-section h3 {
            color: #333;
            margin-bottom: 15px;
        }

        .activity-item {
            background: #f8f9fa;
            padding: 15px;
            margin-bottom: 10px;
            border-radius: 8px;
            border-left: 3px solid #667eea;
        }

        .error-message {
            background: #fff3cd;
            border: 1px solid #ffc107;
            color: #856404;
            padding: 20px;
            border-radius: 10px;
            margin-top: 20px;
            display: none;
        }

        .footer {
            text-align: center;
            color: white;
            margin-top: 40px;
            padding: 20px;
        }

        .metadata {
            margin-top: 30px;
            padding: 20px;
            background: #e8eaf6;
            border-radius: 10px;
            font-size: 0.9em;
            color: #555;
        }

        @media (max-width: 768px) {
            .input-group {
                flex-direction: column;
            }

            .info-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Header -->
        <div class="header">
            <h1>🇮🇳 GST Record Fetcher</h1>
            <p>Real-time GST Data from Government Portal</p>
            <span class="badge">Production v1.0 - International Grade</span>
        </div>

        <!-- Search Section -->
        <div class="search-section">
            <div class="demo-notice">
                <h4>🔒 Real GST Portal Integration</h4>
                <p>Captcha is fetched directly from GST Portal. Solve it here to get real data!</p>
            </div>

            <h2 style="margin-bottom: 20px; color: #333;">Enter GSTIN Number</h2>
            <div class="input-group">
                <input 
                    type="text" 
                    id="gstinInput" 
                    placeholder="e.g., 27AAPFU0939F1ZV" 
                    maxlength="15"
                    autocomplete="off"
                >
            </div>

            <!-- Captcha Section -->
            <div class="captcha-container" id="captchaContainer" style="display: none;">
                <img id="captchaImage" class="captcha-image" alt="Captcha" onclick="loadCaptcha()">
                <input 
                    type="text" 
                    id="captchaInput" 
                    placeholder="Enter Captcha" 
                    class="captcha-input"
                    style="padding: 15px 20px; font-size: 1.1em; border: 2px solid #ddd; border-radius: 10px;"
                    autocomplete="off"
                >
                <button class="refresh-btn" onclick="loadCaptcha()">🔄 Refresh</button>
            </div>

            <button id="searchBtn" onclick="initiateSearch()">🔍 Get Captcha & Search</button>

            <div class="examples">
                <h4>📋 Try Example GSTINs (Click to use):</h4>
                <span class="example-gstin" onclick="useExample('27AAPFU0939F1ZV')">27AAPFU0939F1ZV</span>
                <span class="example-gstin" onclick="useExample('29AAGCB7383E1Z1')">29AAGCB7383E1Z1</span>
                <span class="example-gstin" onclick="useExample('07AACCS6127N1ZC')">07AACCS6127N1ZC</span>
                <span class="example-gstin" onclick="useExample('26AAVCA3240Q1Z2')">26AAVCA3240Q1Z2</span>
            </div>
        </div>

        <!-- Navigation Links -->
        <div style="text-align: center; margin-bottom: 30px;">
            <a href="/" style="display: inline-block; background: rgba(255, 255, 255, 0.9); color: #667eea; padding: 12px 30px; margin: 0 10px; border-radius: 10px; text-decoration: none; font-weight: 600;">🇮🇳 GST Search</a>
            <a href="/mca.html" style="display: inline-block; background: rgba(255, 255, 255, 0.7); color: #667eea; padding: 12px 30px; margin: 0 10px; border-radius: 10px; text-decoration: none; font-weight: 600;">🏢 MCA Search</a>
        </div>

        <!-- Search Section -->
        <div class="search-section">
            <div class="demo-notice">
                <h4>🔒 Real GST Portal Integration</h4>
                <p>Captcha is fetched directly from GST Portal. Solve it here to get real data!</p>
            </div>

            <h2 style="margin-bottom: 20px; color: #333;">Enter GSTIN Number</h2>
            <div class="input-group">
                <input 
                    type="text" 
                    id="gstinInput" 
                    placeholder="e.g., 27AAPFU0939F1ZV" 
                    maxlength="15"
                    autocomplete="off"
                >
            </div>

            <!-- Captcha Section -->
            <div class="captcha-container" id="captchaContainer" style="display: none;">
                <img id="captchaImage" class="captcha-image" alt="Captcha" onclick="loadCaptcha()">
                <input 
                    type="text" 
                    id="captchaInput" 
                    placeholder="Enter Captcha" 
                    class="captcha-input"
                    style="padding: 15px 20px; font-size: 1.1em; border: 2px solid #ddd; border-radius: 10px;"
                    autocomplete="off"
                >
                <button class="refresh-btn" onclick="loadCaptcha()">🔄 Refresh</button>
            </div>

            <button id="searchBtn" onclick="initiateSearch()">🔍 Get Captcha & Search</button>

            <div class="examples">
                <h4>📋 Try Example GSTINs (Click to use):</h4>
                <span class="example-gstin" onclick="useExample('27AAPFU0939F1ZV')">27AAPFU0939F1ZV</span>
                <span class="example-gstin" onclick="useExample('29AAGCB7383E1Z1')">29AAGCB7383E1Z1</span>
                <span class="example-gstin" onclick="useExample('07AACCS6127N1ZC')">07AACCS6127N1ZC</span>
                <span class="example-gstin" onclick="useExample('26AAVCA3240Q1Z2')">26AAVCA3240Q1Z2</span>
            </div>
        </div>

        <!-- Loading -->
        <div class="loading" id="loading">
            <div class="spinner"></div>
            <h3>Fetching GST data from Government Portal...</h3>
            <p>This may take a few moments</p>
        </div>

        <!-- Error Message -->
        <div class="error-message" id="errorMessage"></div>

        <!-- Results Section -->
        <div class="result-section" id="resultSection">
            <div class="result-header">
                <h2>📊 GST Details</h2>
                <span class="status-badge" id="statusBadge"></span>
            </div>

            <div class="info-grid" id="infoGrid"></div>

            <div class="address-section" id="addressSection"></div>

            <div class="activities-section" id="activitiesSection"></div>
            
            <div class="activities-section" id="jurisdictionSection"></div>
            
            <div class="activities-section" id="hsnSection"></div>

            <div class="activities-section" id="filingSection" style="display: none; margin-top: 30px;">
                <h3>📋 Return Filing Information</h3>
                <div style="margin-top: 15px;">
                    <label for="yearSelect" style="font-weight: 600; margin-right: 10px;">Select Financial Year:</label>
                    <select id="yearSelect" style="padding: 8px 15px; border: 1px solid #ddd; border-radius: 5px; font-size: 14px;">
                        <option value="">-- Select Year --</option>
                    </select>
                    <button id="loadFilingBtn" style="margin-left: 10px; padding: 8px 20px; background: #007bff; color: white; border: none; border-radius: 5px; cursor: pointer; font-weight: 600;">Load Filing Data</button>
                </div>
                <div id="filingTableContainer" style="margin-top: 20px;"></div>
            </div>

            <div class="metadata" id="metadata"></div>
        </div>

        <!-- Footer -->
        <div class="footer">
            <p>💼 GST Record Fetcher | Government of India</p>
            <p>Data fetched from official GST Portal</p>
        </div>
    </div>

    <script>
        let sessionId = null;
        let captchaLoaded = false;
        let currentGSTIN = null;

        // Load captcha from backend
        async function loadCaptcha(gstin) {
            try {
                if (!gstin) {
                    const gstinInput = document.getElementById('gstinInput').value.trim().toUpperCase();
                    if (!gstinInput) {
                        showError('Please enter GSTIN first');
                        return;
                    }
                    gstin = gstinInput;
                }

                console.log('Loading captcha for GSTIN:', gstin);
                document.getElementById('captchaImage').src = '';
                document.getElementById('captchaInput').value = '';
                
                // Send GSTIN to backend
                const response = await fetch(`/api/captcha?gstin=${encodeURIComponent(gstin)}`);
                const result = await response.json();

                console.log('Captcha response:', result);

                if (result.success) {
                    console.log('Captcha data length:', result.captcha.length);
                    document.getElementById('captchaImage').src = result.captcha;
                    sessionId = result.sessionId;
                    captchaLoaded = true;
                    currentGSTIN = gstin;
                    document.getElementById('captchaContainer').style.display = 'flex';
                    document.getElementById('searchBtn').textContent = '🔍 Submit Captcha & Search';
                    console.log('✓ Captcha loaded successfully');
                } else {
                    console.error('Captcha load failed:', result.error);
                    showError('Failed to load captcha: ' + result.error);
                }
            } catch (error) {
                console.error('Captcha error:', error);
                showError('Network error while loading captcha: ' + error.message);
            }
        }

        // Initiate search - load captcha first
        async function initiateSearch() {
            const gstin = document.getElementById('gstinInput').value.trim().toUpperCase();
            
            if (!gstin) {
                showError('Please enter a GSTIN number');
                return;
            }

            if (gstin.length !== 15) {
                showError('GSTIN must be exactly 15 characters');
                return;
            }

            if (!captchaLoaded) {
                // Load captcha first time (this enters GSTIN on portal)
                await loadCaptcha(gstin);
            } else {
                // Captcha already loaded, proceed with search
                await searchGSTIN();
            }
        }

        // Search GSTIN with captcha
        async function searchGSTIN() {
            const gstin = document.getElementById('gstinInput').value.trim().toUpperCase();
            const captcha = document.getElementById('captchaInput').value.trim();
            
            // Validate
            if (!gstin) {
                showError('Please enter a GSTIN number');
                return;
            }

            if (gstin.length !== 15) {
                showError('GSTIN must be exactly 15 characters');
                return;
            }

            if (!captcha) {
                showError('Please enter the captcha');
                return;
            }

            // Show loading
            document.getElementById('loading').style.display = 'block';
            document.getElementById('resultSection').style.display = 'none';
            document.getElementById('errorMessage').style.display = 'none';
            document.getElementById('searchBtn').disabled = true;

            try {
                const response = await fetch('/api/gst/search', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        gstin: gstin,
                        captcha: captcha,
                        sessionId: sessionId
                    })
                });

                const result = await response.json();

                if (result.success) {
                    displayResults(result.data, { 
                        fetchedAt: new Date().toISOString(),
                        executionTime: '< 2s',
                        source: 'GST Portal (Real Data)'
                    });
                    
                    // Load filing years after successful search
                    await loadFilingYears(gstin);
                    
                    // Reset for next search
                    captchaLoaded = false;
                    document.getElementById('captchaContainer').style.display = 'none';
                    document.getElementById('searchBtn').textContent = '🔍 Get Captcha & Search';
                } else {
                    showError(result.error || 'Failed to fetch GST data. Please check captcha and try again.');
                    // Reload captcha on error
                    await loadCaptcha();
                }
            } catch (error) {
                showError('Network error: ' + error.message);
                await loadCaptcha();
            } finally {
                document.getElementById('loading').style.display = 'none';
                document.getElementById('searchBtn').disabled = false;
            }
        }

        // Use example GSTIN
        function useExample(gstin) {
            document.getElementById('gstinInput').value = gstin;
            captchaLoaded = false;
            document.getElementById('captchaContainer').style.display = 'none';
            document.getElementById('searchBtn').textContent = '🔍 Get Captcha & Search';
        }

        // Display results
        function displayResults(data, metadata) {
            console.log('Displaying data:', data); // Debug log
            
            // Status badge
            const statusBadge = document.getElementById('statusBadge');
            const isActive = data.status && data.status.toLowerCase().includes('active');
            statusBadge.textContent = isActive ? '✅ Active' : '❌ Inactive';
            statusBadge.className = `status-badge ${isActive ? 'status-active' : 'status-inactive'}`;

            // Info grid
            const infoGrid = document.getElementById('infoGrid');
            infoGrid.innerHTML = `
                <div class="info-card">
                    <h3>GSTIN Number</h3>
                    <p>${data.gstin || 'N/A'}</p>
                </div>
                <div class="info-card">
                    <h3>Legal Name</h3>
                    <p>${data.legalName || 'N/A'}</p>
                </div>
                <div class="info-card">
                    <h3>Trade Name</h3>
                    <p>${data.tradeName || 'Same as Legal Name'}</p>
                </div>
                <div class="info-card">
                    <h3>Effective Date of Registration</h3>
                    <p>${data.registrationDate || data.effectiveDate || 'N/A'}</p>
                </div>
                <div class="info-card">
                    <h3>Constitution of Business</h3>
                    <p>${data.constitutionOfBusiness || 'N/A'}</p>
                </div>
                <div class="info-card">
                    <h3>Taxpayer Type</h3>
                    <p>${data.taxpayerType || 'N/A'}</p>
                </div>
            `;

            // Address section
            const addressSection = document.getElementById('addressSection');
            let addressHTML = `<h3>🏢 Principal Place of Business</h3>
                <p style="color: #555; line-height: 1.6;">${data.principalAddress || 'Address not available'}</p>`;
            
            if (data.aadhaarValidation) {
                addressHTML += `<p style="margin-top: 15px; color: #555; font-size: 14px;">
                    <strong>Whether Aadhaar Authenticated?</strong> ${data.aadhaarValidation}
                    ${data.aadhaarValidationDate ? ` <span style="color: #666;">(On ${data.aadhaarValidationDate})</span>` : ''}
                </p>`;
            }
            if (data.eInvoiceStatus) {
                addressHTML += `<p style="color: #555; font-size: 14px; margin-top: 8px;">
                    <strong>e-Invoice Status:</strong> ${data.eInvoiceStatus}
                </p>`;
            }
            if (data.fieldVisitConducted) {
                addressHTML += `<p style="color: #555; font-size: 14px; margin-top: 8px;">
                    <strong>Field Visit Conducted:</strong> ${data.fieldVisitConducted}
                </p>`;
            }
            addressSection.innerHTML = addressHTML;

            // Jurisdiction sections
            const jurisdictionSection = document.getElementById('jurisdictionSection');
            let jurisdictionHTML = '';
            
            if (data.centerJurisdiction) {
                // Parse center jurisdiction string
                const ctjText = data.centerJurisdiction;
                jurisdictionHTML += `
                    <h3>🏛️ Administrative Office (Jurisdiction - Center)</h3>
                    <div class="activity-item" style="padding: 15px; background: #f8f9fa; border-left: 4px solid #007bff; margin-bottom: 15px;">
                        <p style="margin: 0; color: #555; line-height: 1.8;">${ctjText}</p>
                    </div>
                `;
            }
            
            if (data.stateJurisdiction) {
                // Parse state jurisdiction string
                const stjText = data.stateJurisdiction;
                jurisdictionHTML += `
                    <h3 style="margin-top: 20px;">🏛️ Other Office (Jurisdiction - State)</h3>
                    <div class="activity-item" style="padding: 15px; background: #f8f9fa; border-left: 4px solid #28a745; margin-bottom: 15px;">
                        <p style="margin: 0; color: #555; line-height: 1.8;">${stjText}</p>
                    </div>
                `;
            }
            
            jurisdictionSection.innerHTML = jurisdictionHTML;
            jurisdictionSection.style.display = jurisdictionHTML ? 'block' : 'none';

            // Activities section
            const activitiesSection = document.getElementById('activitiesSection');
            let activitiesHTML = '';
            
            if (data.natureOfBusinessActivities && data.natureOfBusinessActivities.length > 0) {
                activitiesHTML += '<h3>💼 Nature of Business Activities</h3>';
                activitiesHTML += '<div style="display: flex; flex-wrap: wrap; gap: 10px; margin-top: 15px;">';
                data.natureOfBusinessActivities.forEach((activity, idx) => {
                    activitiesHTML += `
                        <div class="activity-item" style="flex: 0 0 auto; padding: 10px 20px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border-radius: 25px; font-weight: 500; box-shadow: 0 4px 6px rgba(102,126,234,0.3);">
                            ${idx + 1}. ${activity}
                        </div>
                    `;
                });
                activitiesHTML += '</div>';
            }
            
            activitiesSection.innerHTML = activitiesHTML;
            activitiesSection.style.display = activitiesHTML ? 'block' : 'none';

            // HSN Codes section (Goods and Services)
            const hsnSection = document.getElementById('hsnSection');
            if (data.goodsAndServices && data.goodsAndServices.length > 0) {
                let hsnHTML = '<h3>📦 Dealing In Goods and Services</h3>';
                hsnHTML += '<p style="color: #666; font-size: 13px; margin-top: 5px; margin-bottom: 20px;">HSN: Harmonized System of Nomenclature of Goods and Services</p>';
                
                hsnHTML += '<table style="width: 100%; border-collapse: collapse; margin-top: 15px;">';
                hsnHTML += '<thead><tr style="background: #f8f9fa; border-bottom: 2px solid #dee2e6;">';
                hsnHTML += '<th style="padding: 12px; text-align: left; font-weight: 600; color: #495057;">HSN Code</th>';
                hsnHTML += '<th style="padding: 12px; text-align: left; font-weight: 600; color: #495057;">Description</th>';
                hsnHTML += '</tr></thead>';
                hsnHTML += '<tbody>';
                
                data.goodsAndServices.forEach((item, idx) => {
                    const bgColor = idx % 2 === 0 ? '#ffffff' : '#f8f9fa';
                    hsnHTML += `
                        <tr style="background: ${bgColor}; border-bottom: 1px solid #dee2e6;">
                            <td style="padding: 12px; font-family: 'Courier New', monospace; color: #007bff; font-weight: 600;">${item.hsnCode}</td>
                            <td style="padding: 12px; color: #555;">${item.description}</td>
                        </tr>
                    `;
                });
                
                hsnHTML += '</tbody></table>';
                hsnSection.innerHTML = hsnHTML;
                hsnSection.style.display = 'block';
            } else {
                hsnSection.style.display = 'none';
            }

            // Metadata
            const metadataDiv = document.getElementById('metadata');
            metadataDiv.innerHTML = `
                <strong>📅 Fetched At:</strong> ${new Date(metadata.fetchedAt).toLocaleString('en-IN')}<br>
                <strong>⏱️ Execution Time:</strong> ${metadata.executionTime}<br>
                <strong>🔗 Source:</strong> ${metadata.source}
                ${data._goodServiceIncluded ? '<br><strong>✅ Goods/Services Data:</strong> Included' : '<br><strong>⚠️ Goods/Services Data:</strong> Not Available'}
                ${data._note ? `<br><br><strong>⚠️ Note:</strong> ${data._note}` : ''}
            `;

            // Show results
            document.getElementById('resultSection').style.display = 'block';
            document.getElementById('resultSection').scrollIntoView({ behavior: 'smooth' });
        }

        // Show error
        function showError(message) {
            const errorDiv = document.getElementById('errorMessage');
            errorDiv.textContent = '❌ ' + message;
            errorDiv.style.display = 'block';
            setTimeout(() => {
                errorDiv.style.display = 'none';
            }, 5000);
        }

        // Load filing years for GSTIN
        async function loadFilingYears(gstin) {
            try {
                console.log('Loading filing years for GSTIN:', gstin);
                console.log('Session ID:', sessionId);
                
                if (!sessionId) {
                    console.error('No session ID available');
                    return;
                }
                
                const response = await fetch(`/api/filing/years?gstin=${encodeURIComponent(gstin)}&sessionId=${sessionId}`);
                const result = await response.json();
                
                console.log('Filing years response:', result);
                
                if (result.success && result.years) {
                    const yearSelect = document.getElementById('yearSelect');
                    yearSelect.innerHTML = '<option value="">-- Select Year --</option>';
                    
                    result.years.forEach(year => {
                        const option = document.createElement('option');
                        option.value = year.value;
                        option.textContent = year.year;
                        yearSelect.appendChild(option);
                    });
                    
                    // Show filing section
                    const filingSection = document.getElementById('filingSection');
                    filingSection.style.display = 'block';
                    console.log('Filing section displayed');
                } else {
                    console.error('Failed to get filing years:', result.error);
                }
            } catch (error) {
                console.error('Failed to load filing years:', error);
            }
        }

        // Load filing status for selected year
        async function loadFilingStatus() {
            const yearSelect = document.getElementById('yearSelect');
            const selectedYear = yearSelect.value;
            const gstin = currentGSTIN;
            
            if (!selectedYear) {
                showError('Please select a financial year');
                return;
            }
            
            if (!gstin) {
                showError('No GSTIN found');
                return;
            }

            if (!sessionId) {
                showError('Session expired. Please search again.');
                return;
            }
            
            const loadBtn = document.getElementById('loadFilingBtn');
            loadBtn.disabled = true;
            loadBtn.textContent = 'Loading...';
            
            try {
                const response = await fetch('/api/filing/status', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        gstin: gstin,
                        financialYear: selectedYear,
                        sessionId: sessionId
                    })
                });
                
                const result = await response.json();
                
                if (result.success && result.filingStatus) {
                    displayFilingTable(result.filingStatus);
                } else {
                    showError('No filing data found for selected year');
                }
            } catch (error) {
                showError('Failed to load filing status: ' + error.message);
            } finally {
                loadBtn.disabled = false;
                loadBtn.textContent = 'Load Filing Data';
            }
        }

        // Display filing table
        function displayFilingTable(filingData) {
            const container = document.getElementById('filingTableContainer');
            
            if (!filingData || filingData.length === 0) {
                container.innerHTML = '<p style="color: #666; text-align: center; padding: 20px;">No filing records found</p>';
                return;
            }
            
            // Group by return type
            const gstr1 = filingData.filter(f => f.rtntype === 'GSTR1');
            const gstr3b = filingData.filter(f => f.rtntype === 'GSTR3B');
            const others = filingData.filter(f => f.rtntype !== 'GSTR1' && f.rtntype !== 'GSTR3B');
            
            let html = '<div style="overflow-x: auto;">';
            
            // GSTR1 Table
            if (gstr1.length > 0) {
                html += '<h4 style="margin-top: 20px; color: #495057;">📊 GSTR-1 Returns</h4>';
                html += '<table style="width: 100%; border-collapse: collapse; margin-top: 10px; font-size: 14px;">';
                html += '<thead><tr style="background: #007bff; color: white;">';
                html += '<th style="padding: 12px; text-align: left;">Tax Period</th>';
                html += '<th style="padding: 12px; text-align: left;">Mode of Filing</th>';
                html += '<th style="padding: 12px; text-align: left;">Date of Filing</th>';
                html += '<th style="padding: 12px; text-align: center;">Status</th>';
                html += '</tr></thead><tbody>';
                
                gstr1.forEach((item, idx) => {
                    const bgColor = idx % 2 === 0 ? '#ffffff' : '#f8f9fa';
                    const statusColor = item.status === 'Filed' ? '#28a745' : '#dc3545';
                    html += `<tr style="background: ${bgColor}; border-bottom: 1px solid #dee2e6;">`;
                    html += `<td style="padding: 10px;">${item.taxp}</td>`;
                    html += `<td style="padding: 10px;">${item.mof}</td>`;
                    html += `<td style="padding: 10px;">${item.dof}</td>`;
                    html += `<td style="padding: 10px; text-align: center;"><span style="background: ${statusColor}; color: white; padding: 4px 12px; border-radius: 12px; font-weight: 600; font-size: 12px;">${item.status}</span></td>`;
                    html += '</tr>';
                });
                html += '</tbody></table>';
            }
            
            // GSTR3B Table
            if (gstr3b.length > 0) {
                html += '<h4 style="margin-top: 30px; color: #495057;">📊 GSTR-3B Returns</h4>';
                html += '<table style="width: 100%; border-collapse: collapse; margin-top: 10px; font-size: 14px;">';
                html += '<thead><tr style="background: #28a745; color: white;">';
                html += '<th style="padding: 12px; text-align: left;">Tax Period</th>';
                html += '<th style="padding: 12px; text-align: left;">Mode of Filing</th>';
                html += '<th style="padding: 12px; text-align: left;">Date of Filing</th>';
                html += '<th style="padding: 12px; text-align: center;">Status</th>';
                html += '</tr></thead><tbody>';
                
                gstr3b.forEach((item, idx) => {
                    const bgColor = idx % 2 === 0 ? '#ffffff' : '#f8f9fa';
                    const statusColor = item.status === 'Filed' ? '#28a745' : '#dc3545';
                    html += `<tr style="background: ${bgColor}; border-bottom: 1px solid #dee2e6;">`;
                    html += `<td style="padding: 10px;">${item.taxp}</td>`;
                    html += `<td style="padding: 10px;">${item.mof}</td>`;
                    html += `<td style="padding: 10px;">${item.dof}</td>`;
                    html += `<td style="padding: 10px; text-align: center;"><span style="background: ${statusColor}; color: white; padding: 4px 12px; border-radius: 12px; font-weight: 600; font-size: 12px;">${item.status}</span></td>`;
                    html += '</tr>';
                });
                html += '</tbody></table>';
            }
            
            // Other Returns
            if (others.length > 0) {
                html += '<h4 style="margin-top: 30px; color: #495057;">📊 Other Returns</h4>';
                html += '<table style="width: 100%; border-collapse: collapse; margin-top: 10px; font-size: 14px;">';
                html += '<thead><tr style="background: #6c757d; color: white;">';
                html += '<th style="padding: 12px; text-align: left;">Return Type</th>';
                html += '<th style="padding: 12px; text-align: left;">Tax Period</th>';
                html += '<th style="padding: 12px; text-align: left;">Mode of Filing</th>';
                html += '<th style="padding: 12px; text-align: left;">Date of Filing</th>';
                html += '<th style="padding: 12px; text-align: center;">Status</th>';
                html += '</tr></thead><tbody>';
                
                others.forEach((item, idx) => {
                    const bgColor = idx % 2 === 0 ? '#ffffff' : '#f8f9fa';
                    const statusColor = item.status === 'Filed' ? '#28a745' : '#dc3545';
                    html += `<tr style="background: ${bgColor}; border-bottom: 1px solid #dee2e6;">`;
                    html += `<td style="padding: 10px; font-weight: 600;">${item.rtntype}</td>`;
                    html += `<td style="padding: 10px;">${item.taxp}</td>`;
                    html += `<td style="padding: 10px;">${item.mof}</td>`;
                    html += `<td style="padding: 10px;">${item.dof}</td>`;
                    html += `<td style="padding: 10px; text-align: center;"><span style="background: ${statusColor}; color: white; padding: 4px 12px; border-radius: 12px; font-weight: 600; font-size: 12px;">${item.status}</span></td>`;
                    html += '</tr>';
                });
                html += '</tbody></table>';
            }
            
            html += '</div>';
            container.innerHTML = html;
        }

        // Event listener for filing button
        document.getElementById('loadFilingBtn').addEventListener('click', loadFilingStatus);

        // Enter key support
        document.getElementById('gstinInput').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                initiateSearch();
            }
        });

        document.getElementById('captchaInput').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                searchGSTIN();
            }
        });

        // Auto-uppercase
        document.getElementById('gstinInput').addEventListener('input', function(e) {
            this.value = this.value.toUpperCase();
        });

        document.getElementById('captchaInput').addEventListener('input', function(e) {
            this.value = this.value.toUpperCase();
        });

        document.getElementById('captchaInput').addEventListener('input', function(e) {
            this.value = this.value.toUpperCase();
        });
    </script>
</body>
</html>
