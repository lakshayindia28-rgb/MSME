# GST Portal Configuration
GST_PORTAL_BASE_URL=https://services.gst.gov.in
REQUEST_TIMEOUT=30000
MAX_RETRIES=3

# Output Settings
OUTPUT_FORMAT=console
# Options: console, json, pdf

# MongoDB
